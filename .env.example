# Discord
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DISCORD_APP_NAME=Music Bot

# YouTube Music API
# Leave empty for unauthenticated mode (search + playback work fine).
# For OAuth: run `uv run python -c "from ytmusicapi import setup_oauth; setup_oauth('ID', 'SECRET', filepath='data/oauth.json')"`
YTM_AUTH_MODE=none              # "oauth", "cookie", or "none" (unauthenticated)
YTM_AUTH_FILE=data/oauth.json
GOOGLE_CLIENT_ID=         # optional — only needed for OAuth mode
GOOGLE_CLIENT_SECRET=     # optional — only needed for OAuth mode

# Commands
COMMAND_PREFIX=!
OWNER_IDS=

# Audio defaults
DEFAULT_VOLUME=0.5
MAX_QUEUE_LENGTH=500
AUTO_DISCONNECT_TIMEOUT=300

# Radio auto-suggest (queue end behavior)
YT_RADIO_ENABLED=true
SUGGESTION_TIMEOUT=30

# Proxy & debug
YT_PROXY=
LOG_LEVEL=INFO
